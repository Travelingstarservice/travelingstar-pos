<!DOCTYPE html>
<html>
<head>
  <title>TravelingStar POS - Admin Panel</title>
</head>
<body>
  <h1>Admin Panel - TravelingStar POS</h1>
  <table border="1" id="bookings-table">
    <thead>
      <tr>
        <th>ID</th>
        <th>Name</th>
        <th>Phone</th>
        <th>Amount</th>
        <th>Payment Method</th>
        <th>Status</th>
        <th>Action</th>
        <th>QR Code</th>
      </tr>
    </thead>
    <tbody>
    </tbody>
  </table>

  <script>
    const tableBody = document.querySelector("#bookings-table tbody");

    async function fetchBookings() {
      const res = await fetch('http://localhost:3000/bookings');
      const bookings = await res.json();

      tableBody.innerHTML = ''; // Clear table

      bookings.forEach(b => {
        const row = document.createElement('tr');

        row.innerHTML = `
          <td>${b.id}</td>
          <td>${b.customerName}</td>
          <td>${b.phone}</td>
          <td>$${b.amount}</td>
          <td>${b.paymentMethod}</td>
          <td>${b.status}</td>
          <td>
            ${b.status === 'PENDING_PAYMENT' ? `<button onclick="confirmPayment(${b.id})">Confirm</button>` : ''}
          </td>
          <td>
            <img src="https://api.qrserver.com/v1/create-qr-code/?size=100x100&data=https://cash.app/$TravelingSS/${b.id}" />
          </td>
        `;

        tableBody.appendChild(row);
      });
    }

    async function confirmPayment(id) {
      await fetch('http://localhost:3000/confirm-payment', {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify({id})
      });
    }

    fetchBookings();

    setInterval(fetchBookings, 5000);
  </script>
</body>
</html>

